# =============================================================
#  Все переменные НЕОБЯЗАТЕЛЬНЫ.
#  Если их не задать, проект запустится в DEMO-режиме:
#    - данные хранятся в localStorage браузера;
#    - вход в /admin по паролю из VITE_ADMIN_PASSWORD (см. ниже).
# =============================================================

# Supabase (если не заданы — включается DEMO-режим на localStorage)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# anon (Legacy) или sb_publishable_... из Supabase → API Keys
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Пароль администратора (скрытый маршрут /admin, ссылок на сайте нет).
VITE_ADMIN_PASSWORD=

# Публичный адрес для «Поделиться» (по умолчанию https://obninsk70.ru).
# VITE_PUBLIC_SITE_URL=https://obninsk70.ru
