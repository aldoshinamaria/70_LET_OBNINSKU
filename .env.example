# =============================================================
#  Все переменные НЕОБЯЗАТЕЛЬНЫ.
#  Если их не задать, проект запустится в DEMO-режиме:
#    - данные хранятся в localStorage браузера;
#    - вход в админку по демо-паролю admin2026.
# =============================================================

# Supabase (если не заданы — включается DEMO-режим на localStorage)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Пароль администратора (маршрут /admin).
# Если не задан — используется демо-пароль admin2026.
VITE_ADMIN_PASSWORD=change-me-please
